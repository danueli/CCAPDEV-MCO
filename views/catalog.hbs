<!DOCTYPE html>
<html>
    <!-- Header -->
    <header class="navbar">
      <image src="/Search.png" height="75"></image>
      <nav>
        <a href="/main/{{username}}">Home</a>
        <a href="/catalog/{{username}}">Catalog</a>
        <a href="/help">Help</a>
        <a href="/login">Logout</a>
        <a href="/profile/{{username}}">Profile</a>
        {{#if isManager}}
          <a href="/products/add?username={{username}}">Add Product</a>
        {{/if}}
        <a href="/cart/{{username}}">
          <img src="/cart-icon.png" alt="Cart" height="40">
        </a>
      </nav>
    </header>

    <!-- Catalog Heading -->
    <h2 class="catalog-heading">Our Pastries</h2>
    <p class="catalog-subheading">Click any item to see reviews</p>

    <!-- Category Filters -->
    <div class="category-filter" style="margin: 18px 0; display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
      <a href="/catalog/{{username}}" class="category-pill {{#if (eq selectedCategory 'All')}}active{{/if}}">All</a>
      {{#each categories}}
        <a href="/catalog/{{../username}}?category={{this}}" class="category-pill {{#if (eq this ../selectedCategory)}}active{{/if}}">{{this}}</a>
      {{/each}}
    </div>

    <!-- Product Grid -->
    <div class="product-container">
      {{#each products}}
        <a href="/products/{{this._id}}?username={{../username}}" class="product-box">
          <img src="/{{this.image}}" alt="{{this.name}}" class="product-img">
          <div class="card-overlay">
            <h3>{{this.name}}</h3>
            <p>{{this.description}}</p>
            <div class="stars">★★★★★</div>
          </div>
        </a>
      {{else}}
        <p>No products available.</p>
      {{/each}}
    </div>

    <footer class="footer">
      <p>CCAPDEV S12 Team Gardenia</p>
    </footer>

  </body>
</html>
