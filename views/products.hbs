<!DOCTYPE html>
<html>
  <head>
    <title>Bakehub | Products</title>
    <link rel="icon" type="image/png" href="/bakehub_favicon.png">
    <link rel="stylesheet" href="/style.css">
  </head>
  <body>

    <!-- Header -->
    <header class="navbar">
      <image src="/bakehub_bg.png" height="75"></image>
      <nav>
        <a href="/main/{{username}}">Home</a>
        <a href="/catalog/{{username}}">Catalog</a>
        <a href="/help">Help</a>
        <a href="/logout">Logout</a>
        <a href="/profile/{{username}}">Profile</a>
        {{#if isAdmin}}
          <a href="/products/add?username={{username}}">Add Product</a>
        {{/if}}
        <a href="/cart/{{username}}">
          <img src="/cart-icon.png" alt="Cart" height="40">
        </a>
      </nav>
    </header>

    <!-- Heading -->
    <h2 class="catalog-heading">Our Pastries</h2>
    <p class="catalog-subheading">Click any item to see more details and reviews</p>

    <!-- Search Bar -->
    <div class="search-container">
      <form method="GET" action="/search">
        <input type="hidden" name="username" value="{{username}}">
        <input type="text" name="q" placeholder="Search pastries..." class="search-input" value="{{query}}">
        <button type="submit" class="search-btn">Search</button>
      </form>
    </div>

    <!-- Product Grid -->
    <div class="product-container">
      {{#each products}}
        <div class="product-box">

          <!-- Click image/name to go to product detail -->
          <a href="/products/{{this._id}}?username={{../username}}">
            <img src="/{{this.image}}" alt="{{this.name}}" class="product-img">
            <div class="card-overlay">
              <h3>{{this.name}}</h3>
              <p>{{this.description}}</p>
              <p class="price">₱{{this.price}}</p>
              <p class="stock">Stock: {{this.stock}}</p>
            </div>
          </a>

          <!-- Add to Cart form -->
          <form class="add-to-cart-form" method="POST" action="/cart/add/{{../username}}">
            <input type="hidden" name="productId" value="{{this._id}}">
            <input type="number" name="quantity" value="1" min="1" max="{{this.stock}}">
            <button type="submit" class="add-to-cart-btn">Add to Cart</button>
          </form>

          <!-- Manager Edit/Delete buttons -->
          {{#if ../isAdmin}}
            <div style="display: flex; gap: 5px; margin-top: 10px;">
              <a href="/products/{{this._id}}/edit?username={{../username}}" class="btn btn-sm btn-warning" style="flex: 1; padding: 8px; text-align: center; background-color: #ff9800; color: white; border-radius: 5px; text-decoration: none;">Edit</a>
              <button onclick="deleteProduct('{{this._id}}', '{{../username}}')" class="btn btn-sm btn-danger" style="flex: 1; padding: 8px; background-color: #f44336; color: white; border: none; border-radius: 5px; cursor: pointer;">Delete</button>
            </div>
          {{/if}}

        </div>
      {{else}}
        <p>No products found.</p>
      {{/each}}
    </div>

    <footer class="footer">
      <p>CCAPDEV S12 Team Gardenia</p>
    </footer>

    <script src="/script.js"></script>
    <script>
      function deleteProduct(productId, username) {
        if (confirm('Are you sure you want to delete this product?')) {
          fetch(`/products/${productId}/delete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username })
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              alert('Product deleted successfully');
              location.reload();
            } else {
              alert('Error: ' + data.error);
            }
          })
          .catch(err => alert('Error: ' + err.message));
        }
      }
    </script>
  </body>
</html>
