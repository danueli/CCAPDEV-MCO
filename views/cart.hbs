<!DOCTYPE html>
<html>

<body>

  <!-- Header -->
  <header class="navbar">
    <image src="/Search.png" height="75"></image>
    <nav>
      <a href="/main/{{username}}">Home</a>
      <a href="/catalog/{{username}}">Catalog</a>
      <a href="/help">Help</a>
      <a href="/login">Logout</a>
      <a href="/profile/{{username}}">Profile</a>
      {{#if isManager}}
        <a href="/products/add?username={{username}}">Add Product</a>
      {{/if}}
      <a href="/cart/{{username}}">
        <img src="/cart-icon.png" alt="Cart" height="40">
      </a>
    </nav>
  </header>

  <!-- Cart Page Content -->
  <main class="main-content">
    <h2>My Cart</h2>

    {{#if cart.items.length}}
      <div class="cart-items">
        {{#each cart.items}}
          <div class="cart-item">
            <img src="/{{this.productId.image}}" alt="{{this.productId.name}}" height="80">
            <div>
              <h3>{{this.productId.name}}</h3>
              <p>₱{{this.productId.price}} x {{this.quantity}}</p>
            </div>

            <div class="cart-actions">
              <form method="POST" action="/cart/update/{{../username}}" class="qty-form">
                <input type="hidden" name="productId" value="{{this.productId._id}}">
                <button type="submit" name="delta" value="-1">-</button>
                <span>{{this.quantity}}</span>
                <button type="submit" name="delta" value="1">+</button>
              </form>

              <form method="POST" action="/cart/remove/{{../username}}">
                <input type="hidden" name="productId" value="{{this.productId._id}}">
                <button type="submit">Remove</button>
              </form>
            </div>
          </div>
        {{/each}}
      </div>

      <div class="cart-footer">
        <div class="cart-total">
          <span>Total:</span>
          <span>₱{{cart.totalPrice}}</span>
        </div>
        <a href="/checkout/{{username}}" class="checkout-btn">Proceed to Checkout</a>
      </div>

    {{else}}
      <div class="empty-cart">
        <img src="/cart-icon.png" alt="Cart Icon">
        <p>Your cart is empty</p>
      </div>
    {{/if}}

  </main>

  <footer class="footer">
    <p>CCAPDEV S12 Team Gardenia</p>
  </footer>

</body>
</html>
