<div class="container mt-5">
  <header class="navbar">
    <image src="/Search.png" height="75"></image>
    <nav>
      <a href="/main/{{username}}">Home</a>
      <a href="/profile/{{username}}">Back to Profile</a>
      {{#if isAdmin}}
        <a href="/products/add?username={{username}}">Add Product</a>
      {{/if}}
      <a href="/cart/{{username}}">
        <img src="/cart-icon.png" alt="Cart" height="40">
      </a>
    </nav>
  </header>
  <div class="row">
    <div class="col-md-12">
      <h1 style = "text-align: center">My Orders</h1>
      <br>
      
      {{#if orders.length}}
        <div class="table-responsive">
          <table class="table table-striped table-hover" bgcolor="black" width = "1000" style = "text-align: center; margin-left: auto; margin-right: auto;">
            <thead class="table-dark">
              <tr bgcolor = "white">
                <th>Order ID</th>
                <th>Date</th>
                <th>Items</th>
                <th>Total Price</th>
                <th>Status</th>
                <th>Address</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {{#each orders}}
                <tr>
                  <td bgcolor = "white"><small>{{this._id}}</small></td>
                  <td bgcolor = "white">{{formatDate this.date}}</td>
                  <td bgcolor = "white">
                    <small>
                      {{#each this.items}}
                        {{this.name}} x{{this.quantity}}<br>
                      {{/each}}
                    </small>
                  </td>
                  <td bgcolor = "white">₱{{this.totalPrice}}</td>
                  <td bgcolor = "white">
                    <span class="badge {{#eq this.status 'Pending'}}bg-warning{{/eq}}{{#eq this.status 'Shipped'}}bg-info{{/eq}}{{#eq this.status 'Delivered'}}bg-success{{/eq}}{{#eq this.status 'Cancelled'}}bg-danger{{/eq}}">
                      {{this.status}}
                    </span>
                  </td>
                  <td bgcolor = "white"><small>{{this.address}}</small></td>
                  <td bgcolor = "white">
                    {{#eq this.status 'Pending'}}
                      <button class="btn btn-sm btn-danger" onclick="deleteOrder('{{this._id}}')">Cancel</button>
                    {{else}}
                      <span class="text-muted">-</span>
                    {{/eq}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <div class="alert alert-info">
          No orders yet. <a href="/catalog/{{username}}">Start shopping!</a>
        </div>
      {{/if}}
    </div>
  </div>
</div>

<script>
function deleteOrder(orderId) {
  if (confirm('Are you sure you want to cancel this order?')) {
    fetch(`/orders/${orderId}/delete`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ username: '{{username}}' })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        alert('Order cancelled successfully');
        location.reload();
      } else {
        alert('Error: ' + data.error);
      }
    })
    .catch(err => alert('Error: ' + err.message));
  }
}
</script>

