<br><br>
   
<main class="login">
    <div class="login-card" id="login-card">
        <h2 class="login title">Sign up as a Manager!</h2> <br>
        
        <form action="/s_signup" method="POST" class="seller-signup-form">
            <div class="input-container">
                <label for="firstName">First Name:</label>
                <input type="text" id="firstName" name="firstName" placeholder="First name" required> <br><br>

                <label for="lastName">Last Name:</label>
                <input type="text" id="lastName" name="lastName" placeholder="Last name" required> <br><br>

                <label for="username">Username:</label>
                <input type="text" id="username" name="username" placeholder="Username" required> <br><br>

                <label for="email">Email:</label>
                <input type="email" id="email" name="email" placeholder="Email" required> <br><br>

                <label for="phone">Phone:</label>
                <input type="tel" id="phone" name="phone" placeholder="Phone number"> <br><br>

                <label for="password">Password:</label>
                <input type="password" id="password" name="password" placeholder="Password" required> <br><br>
            </div>

            {{#if error}}
                <div class="error-message">{{error}}</div>
            {{/if}}

            <button type="submit" class="submit">Sign Up</button>
        </form>
        
        <p style="text-align: center; margin-top: 15px;">
            Already have an account? <a href="/s_login">Login here</a>
        </p>
    </div>
</main>

<!-- Footer -->
<footer class="footer">
    <p>CCAPDEV S12 Team Gardenia</p>
</footer>
